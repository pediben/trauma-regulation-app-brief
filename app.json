{
  "expo": {
    "name": "Regulate",
    "slug": "regulate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "regulate",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1A2E"
    },
    "assetBundlePatterns": [
      "**/*",
      "assets/audio/*.mp3"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.regulate.app",
      "infoPlist": {
        "UIBackgroundModes": ["audio"],
        "NSMicrophoneUsageDescription": "Regulate does not record audio. This permission is required by iOS for audio playback in the background.",
        "NSPhotoLibraryUsageDescription": "Not used.",
        "CFBundleDisplayName": "Regulate",
        "CFBundleShortVersionString": "1.0.0"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F1A2E"
      },
      "package": "com.regulate.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
